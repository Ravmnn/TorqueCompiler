#>external byte* fdopen(int fileDescriptor, char* mode);
external int64 getline(char** buffer, usize* bufferSize, byte* fileDescriptor);
external int printf(char* content);

external int sprintf(char* buffer, char* format, int value);


void intToString(char* buffer, int value)
{
    sprintf(buffer, "%d", value);
}


byte* stdin() { return fdopen(0, "r"); }

char* readln(char* prompt)
{
    char* buffer;
    usize bufferSize;

    if (prompt != default(char*))
        printf(prompt);

    let length = getline(&buffer, &bufferSize, stdin());
    buffer[length - 1] = '\0';

    return buffer;
}


void println(char* content)
{
    printf(content);
    printf("\n");
}<#
















struct Person
{
    char* name;
    uint age;
    uint id;
}


int main(int argc, char** argv)
{
    let people = Person array[] {
        new Person { name: "John Wick", age: 24, id: 047155 },
        new Person { name: "Peter Parker", age: 23, id: 895921 },
        new Person { name: "Ariana Grande", age: 30, id: 991644 },
        new Person { name: "Osmany Something", age: 21, id: 010465 },
        new Person { name: "Marvin Marjan", age: 17, id: 123456 }
    };

    let johnPtr = &people[0];
    let peterPtr = &people[1];
    let arianaPtr = &people[2];
    let osmanyPtr = &people[3];
    let marvinPtr = &people[4];

    people[2].name = "Ariana Small";

    (*arianaPtr).id = 987654 as uint;

    let ariana = people[2];
    ariana.age = 9 as uint;

    return 0;
}