external byte* fdopen(int fileDescriptor, char* mode);
external int64 getline(char** buffer, usize* bufferSize, byte* fileDescriptor);
external int printf(char* content);

external int sprintf(char* buffer, char* format, int value);


void intToString(char* buffer, int value)
{
    sprintf(buffer, "%d", value);
}


byte* stdin() { return fdopen(0, "r"); }

char* readln(char* prompt)
{
    char* buffer;
    usize bufferSize;

    if (prompt != default(char*))
        printf(prompt);

    let length = getline(&buffer, &bufferSize, stdin());
    buffer[length - 1] = '\0';

    return buffer;
}


void println(char* content)
{
    printf(content);
    printf("\n");
}
















struct Person
{
    char* name;
    uint age;
    uint id;
}


int main(int argc, char** argv)
{
    # Person peak = new Person { name: "Kujo Jotaro", age: 20, id: 123456 };

    Person someone;

    someone.name = "Peter Parker";
    someone.age = 20 as uint;
    someone.id = 123456 as uint;
    
    println(someone.name);

    return 0;
}